# --- Frontend (Node.js/Vite) ---
# Never commit the 1000s of library files
**/node_modules/
**/dist/
**/build/
.env
.env.local
npm-debug.log*
yarn-error.log*

# --- Backend (Java/Gradle) ---
.gradle/
build/
out/
bin/
!gradle/wrapper/gradle-wrapper.jar

# --- IDEs (IntelliJ, VS Code, STS) ---
.idea/
*.iml
*.iws
*.ipr
.vscode/
.classpath
.project
.settings/
.nb-gradle/

# --- System & OS Junk ---
# Prevents Windows-specific metadata from entering the repo
Thumbs.db
desktop.ini
.DS_Store

# --- Secrets & Logs ---
# Keep your reseller keys and passwords out of GitHub
/logs/
*.log